// AUTO-GENERATED — do not edit directly.
// Source of truth: config/base.jsonc, config/providers.jsonc, config/lsp.jsonc
// Regenerate: go run scripts/gen-opencode-config.go
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "command": {},
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000
  },
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": false,
    "mcp_timeout": 30000,
    "openTelemetry": true,
    "primary_tools": [
      "read",
      "grep",
      "glob",
      "edit",
      "write",
      "bash"
    ]
  },
  "formatter": {
    "gofmt": {
      "command": [
        "gofmt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".go"
      ]
    },
    "prettier": {
      "command": [
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts",
        ".jsx",
        ".css",
        ".scss",
        ".less",
        ".html",
        ".json",
        ".jsonc",
        ".yaml",
        ".yml",
        ".md",
        ".mdx",
        ".graphql",
        ".gql"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "shfmt": {
      "command": [
        "shfmt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "terraform": {
      "command": [
        "terraform",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".tf",
        ".hcl",
        ".tfvars"
      ]
    }
  },
  "instructions": [
    "~/.config/opencode/rules/hard-autonomy-no-questions.md",
    "~/.config/opencode/rules/archon-workflow.md",
    "~/.config/opencode/rules/session-init.md",
    "~/.config/opencode/rules/requirements-verification.md",
    "~/.config/opencode/rules/monorepo-standards.md",
    "~/.config/opencode/rules/deployment-automation.md",
    "~/.config/opencode/rules/mcp-schema-hygiene.md",
    "~/.config/opencode/rules/code-modularization.md",
    "~/.config/opencode/rules/bmad-integration.md",
    "~/.config/opencode/rules/auto-build-pipeline.md"
  ],
  "keybinds": {
    "display_thinking": "\u003cleader\u003et",
    "leader": "ctrl+x",
    "session_fork": "\u003cleader\u003ef",
    "tool_details": "\u003cleader\u003ed"
  },
  "logLevel": "INFO",
  "lsp": {
    "css": {
      "command": [
        "vscode-css-language-server",
        "--stdio"
      ],
      "extensions": [
        ".css",
        ".scss",
        ".less"
      ],
      "initialization": {
        "css": {
          "validate": true
        },
        "less": {
          "validate": true
        },
        "provideFormatter": false,
        "scss": {
          "validate": true
        }
      }
    },
    "go": {
      "command": [
        "gopls"
      ],
      "env": {
        "GO111MODULE": "on"
      },
      "extensions": [
        ".go"
      ],
      "initialization": {
        "gopls": {
          "analyses": {
            "nilness": true,
            "shadow": true,
            "unusedparams": true
          },
          "completeUnimported": true,
          "directoryFilters": [
            "-node_modules",
            "-.git",
            "-.cache",
            "-tmp"
          ],
          "gofumpt": true,
          "staticcheck": true,
          "usePlaceholders": true
        }
      }
    },
    "html": {
      "command": [
        "vscode-html-language-server",
        "--stdio"
      ],
      "extensions": [
        ".html"
      ],
      "initialization": {
        "provideFormatter": false
      }
    },
    "json": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ],
      "initialization": {
        "json": {
          "schemas": [
            {
              "fileMatch": [
                "package.json"
              ],
              "url": "https://json.schemastore.org/package.json"
            },
            {
              "fileMatch": [
                "tsconfig*.json"
              ],
              "url": "https://json.schemastore.org/tsconfig.json"
            },
            {
              "fileMatch": [
                ".eslintrc",
                ".eslintrc.json"
              ],
              "url": "https://json.schemastore.org/eslintrc.json"
            },
            {
              "fileMatch": [
                ".prettierrc",
                ".prettierrc.json"
              ],
              "url": "https://json.schemastore.org/prettierrc.json"
            }
          ],
          "validate": {
            "enable": true
          }
        },
        "provideFormatter": true
      }
    },
    "lua": {
      "command": [
        "lua-language-server"
      ],
      "extensions": [
        ".lua"
      ],
      "initialization": {
        "Lua": {
          "diagnostics": {
            "enable": true,
            "globals": [
              "vim"
            ],
            "workspaceDelay": 3000,
            "workspaceEvent": "OnSave",
            "workspaceRate": 100
          },
          "hint": {
            "enable": true,
            "paramName": "Disable",
            "semicolon": "Disable"
          },
          "runtime": {
            "path": [
              "lua/?.lua",
              "lua/?/init.lua"
            ],
            "pathStrict": false,
            "version": "LuaJIT"
          },
          "workspace": {
            "checkThirdParty": false,
            "library": [
              "${workspaceFolder}"
            ]
          }
        }
      }
    },
    "markdown": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ]
    },
    "python": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ],
      "initialization": {
        "basedpyright": {
          "analysis": {
            "autoImportCompletions": true,
            "autoSearchPaths": true,
            "configFilePath": "${workspaceFolder}",
            "diagnosticMode": "workspace",
            "diagnosticSeverityOverrides": {
              "reportMissingTypeStubs": "none"
            },
            "inlayHints": {
              "callArgumentNames": true,
              "functionReturnTypes": true,
              "genericTypes": true,
              "variableTypes": true
            },
            "typeCheckingMode": "recommended",
            "useLibraryCodeForTypes": true
          }
        }
      }
    },
    "rust": {
      "command": [
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ],
      "initialization": {
        "cargo": {
          "allTargets": true,
          "buildScripts": {
            "enable": true
          },
          "features": "all"
        },
        "check": {
          "allTargets": true,
          "command": "clippy",
          "extraArgs": [
            "--",
            "-Dwarnings"
          ]
        },
        "checkOnSave": true,
        "files": {
          "exclude": [
            ".git",
            "target",
            "node_modules",
            "tmp",
            ".cache"
          ],
          "watcher": "client"
        },
        "inlayHints": {
          "chainingHints": {
            "enable": true
          },
          "parameterHints": {
            "enable": true
          },
          "typeHints": {
            "enable": true
          }
        },
        "procMacro": {
          "enable": true
        }
      }
    },
    "terraform": {
      "command": [
        "terraform-ls",
        "serve"
      ],
      "extensions": [
        ".tf",
        ".hcl",
        ".tfvars"
      ],
      "initialization": {
        "experimentalFeatures": {
          "validateOnSave": true
        }
      }
    },
    "toml": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts"
      ],
      "initialization": {
        "maxTsServerMemory": 6144,
        "preferences": {
          "importModuleSpecifierEnding": "minimal",
          "importModuleSpecifierPreference": "project-relative",
          "includeCompletionsForImportStatements": true,
          "includeCompletionsForModuleExports": true,
          "includeInlayEnumMemberValueHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": false,
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includePackageJsonAutoImports": "on",
          "interactiveInlayHints": true,
          "organizeImportsTypeOrder": "last"
        },
        "tsserver": {
          "trace": "off",
          "useSyntaxServer": "auto"
        }
      }
    },
    "yaml": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ],
      "extensions": [
        ".yaml",
        ".yml"
      ],
      "initialization": {
        "yaml": {
          "completion": true,
          "format": {
            "enable": false
          },
          "hover": true,
          "schemas": {
            "https://json.schemastore.org/chart.json": "Chart.yaml",
            "https://json.schemastore.org/dependabot-2.0.json": ".github/dependabot.yml",
            "https://json.schemastore.org/docker-compose.json": "docker-compose*.yml",
            "https://json.schemastore.org/github-action.json": "action.yml",
            "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
            "https://json.schemastore.org/kustomization.json": "kustomization.yaml"
          },
          "validate": true
        }
      }
    }
  },
