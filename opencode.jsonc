{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tron",
  "username": "jclee",
  "logLevel": "INFO",

  "instructions": [
    // Tier 1 — Always-loaded baseline rules.
    // Domain/task-specific rules (Tier 2/3) loaded from project-level opencode.jsonc.
    "rules/hard-autonomy-no-questions.md",
    "rules/session-init.md",
    "rules/requirements-verification.md",
    "rules/deployment-automation.md",
    "rules/monorepo-standards.md",
  ],

  "plugin": [
    "oh-my-opencode",
    "opencode-antigravity-auth@latest",
    "opencode-supermemory",
    // "open-trees", // disabled: no clear recent usage evidence
    // "opencode-snippets", // disabled: optional productivity add-on
    "opencode-pilot",
  ],

  // ============================================================
  // PROVIDERS — model definitions
  // ============================================================
  "provider": {
    "google": {
      "options": {
        "timeout": 600000,
        "setCacheKey": true,
      },
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" },
          },
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } },
          },
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
      },
    },
  },

  // ============================================================
  // MCP — remote server
  // ============================================================
  "mcp": {
    "mcphub": {
      "type": "remote",
      "url": "http://192.168.50.112:3000/mcp",
      "timeout": 30000,
      "enabled": true,
    },
  },

  "permission": {
    "*": "allow"
  },

  // ============================================================
  // EXPERIMENTAL — loop control & batch
  // ============================================================
  "experimental": {
    "continue_loop_on_deny": false,
    "batch_tool": true,
    "mcp_timeout": 30000,
    "primary_tools": ["read", "grep", "glob", "edit", "write", "bash"],
  },

  // ============================================================
  // COMPACTION — auto with threshold
  // ============================================================
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000,
  },

  // ============================================================
  // SMALL MODEL — for lightweight tasks (title gen, summaries)
  // ============================================================
  "small_model": "minimax-coding-plan/MiniMax-M2.5-highspeed",
  // ============================================================
  // FORMATTER — per-extension formatting commands
  // ============================================================
  "formatter": {
    ".ts": { "command": ["prettier", "--write"] },
    ".tsx": { "command": ["prettier", "--write"] },
    ".js": { "command": ["prettier", "--write"] },
    ".mjs": { "command": ["prettier", "--write"] },
    ".cjs": { "command": ["prettier", "--write"] },
    ".jsx": { "command": ["prettier", "--write"] },
    ".css": { "command": ["prettier", "--write"] },
    ".html": { "command": ["prettier", "--write"] },
    ".py": { "command": ["ruff", "format"] },
    ".go": { "command": ["gofmt", "-w"] },
    ".json": { "command": ["prettier", "--write"] },
    ".jsonc": { "command": ["prettier", "--write"] },
    ".yaml": { "command": ["prettier", "--write"] },
    ".yml": { "command": ["prettier", "--write"] },
    ".md": { "command": ["prettier", "--write"] },
    ".tf": { "command": ["terraform", "fmt"] },
    ".hcl": { "command": ["terraform", "fmt"] },
    ".toml": { "command": ["taplo", "fmt"] },
  },

  // ============================================================
  // WATCHER — ignore patterns
  // ============================================================
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/.next/**",
      "**/.venv/**",
      "**/coverage/**",
      "**/.terraform/**",
      "**/terraform.tfstate*",
      "**/.cache/**",
      "**/.sisyphus/**",
      "**/logs/**",
      "**/log/**",
      "**/data/**",
      "**/profiles/**",
      "**/tmp/**",
      "**/*.log",
      "**/*.db",
      "**/*.pid",
      "**/*.tmp",
      "**/*.swp",
      "**/*~",
      "**/.DS_Store",
      "**/*.bak.*",
      "**/*.backup-*",
      "antigravity-accounts.json",
      "antigravity-signature-cache.json",
    ],
  },

  // ============================================================
  // TUI — terminal UI settings
  // ============================================================
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": { "enabled": true },
    "diff_style": "auto",
  },

  // ============================================================
  // LSP — Language Server Protocol
  // ============================================================
  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "initialization": {
        "maxTsServerMemory": 6144,
        "tsserver": {
          "useSyntaxServer": "auto",
          "trace": "off",
        },
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": false,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true,
          "interactiveInlayHints": true,
          "includeCompletionsForModuleExports": true,
          "includeCompletionsForImportStatements": true,
          "includePackageJsonAutoImports": "on",
          "importModuleSpecifierPreference": "project-relative",
          "importModuleSpecifierEnding": "minimal",
          "organizeImportsTypeOrder": "last",
        },
      },
    },
    "python": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py"],
      "initialization": {
        "basedpyright": {
          "analysis": {
            "diagnosticMode": "workspace",
            "typeCheckingMode": "recommended",
            "autoImportCompletions": true,
            "inlayHints": {
              "variableTypes": true,
              "callArgumentNames": true,
              "functionReturnTypes": true,
              "genericTypes": true,
            },
            "useLibraryCodeForTypes": true,
            "autoSearchPaths": true,
            "configFilePath": "${workspaceFolder}",
            "diagnosticSeverityOverrides": {
              "reportMissingTypeStubs": "none",
            },
          },
        },
      },
    },
    "go": {
      "command": ["gopls"],
      "extensions": [".go"],
      "env": { "GO111MODULE": "on" },
      "initialization": {
        "gopls": {
          "staticcheck": true,
          "gofumpt": true,
          "usePlaceholders": true,
          "completeUnimported": true,
          "directoryFilters": ["-node_modules", "-.git", "-.cache", "-tmp"],
          "analyses": {
            "unusedparams": true,
            "nilness": true,
            "shadow": true,
          },
        },
      },
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"],
      "initialization": {
        "cargo": {
          "allTargets": true,
          "features": "all",
          "buildScripts": { "enable": true },
        },
        "checkOnSave": true,
        "check": {
          "command": "clippy",
          "allTargets": true,
          "extraArgs": ["--", "-Dwarnings"],
        },
        "procMacro": { "enable": true },
        "files": {
          "watcher": "client",
          "exclude": [".git", "target", "node_modules", "tmp", ".cache"],
        },
        "inlayHints": {
          "typeHints": { "enable": true },
          "parameterHints": { "enable": true },
          "chainingHints": { "enable": true },
        },
      },
    },
    "lua": {
      "command": ["lua-language-server"],
      "extensions": [".lua"],
      "initialization": {
        "Lua": {
          "runtime": {
            "version": "LuaJIT",
            "path": ["lua/?.lua", "lua/?/init.lua"],
            "pathStrict": false,
          },
          "workspace": {
            "checkThirdParty": false,
            "library": ["${workspaceFolder}"],
          },
          "diagnostics": {
            "enable": true,
            "globals": ["vim"],
            "workspaceDelay": 3000,
            "workspaceEvent": "OnSave",
            "workspaceRate": 100,
          },
          "hint": {
            "enable": true,
            "paramName": "Disable",
            "semicolon": "Disable",
          },
        },
      },
    },
    "terraform": {
      "command": ["terraform-ls", "serve"],
      "extensions": [".tf", ".hcl"],
      "initialization": {
        "experimentalFeatures": { "validateOnSave": true },
      },
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"],
      "initialization": {
        "yaml": {
          "validate": true,
          "hover": true,
          "completion": true,
          "format": { "enable": false },
          "schemas": {
            "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
            "https://json.schemastore.org/docker-compose.json": "docker-compose*.yml",
          },
        },
      },
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"],
      "initialization": {
        "provideFormatter": true,
        "json": {
          "validate": { "enable": true },
          "schemas": [
            {
              "fileMatch": ["package.json"],
              "url": "https://json.schemastore.org/package.json",
            },
            {
              "fileMatch": ["tsconfig*.json"],
              "url": "https://json.schemastore.org/tsconfig.json",
            },
          ],
        },
      },
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"],
      "initialization": {
        "provideFormatter": false,
        "css": { "validate": true },
        "scss": { "validate": true },
        "less": { "validate": true },
      },
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html"],
      "initialization": {
        "provideFormatter": false,
      },
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash"],
    },
    "toml": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"],
    },
    "markdown": {
      "command": ["marksman", "server"],
      "extensions": [".md"],
    },
  },

  // ============================================================
  // SKILLS — custom skills paths
  // ============================================================
  "skills": {
    "paths": ["~/.config/opencode/skills"],
    "urls": [],
  },

  // ============================================================
  // COMMAND — custom commands (placeholder)
  // ============================================================
  "command": {},

  // ============================================================
  // SERVER — API server settings
  // ============================================================

  // ============================================================
  // AUTO-UPDATE & SHARING
  // ============================================================
  "autoupdate": "notify",
  "snapshot": true,
  "share": "manual",

  // ============================================================
  // KEYBINDS
  // ============================================================
  "keybinds": {
    "leader": "ctrl+x",
    "tool_details": "<leader>d",
    "session_fork": "<leader>f",
  },
}
