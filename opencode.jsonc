// AUTO-GENERATED — do not edit directly.
// Source of truth: config/base.jsonc, config/providers.jsonc, config/lsp.jsonc
// Regenerate: go run scripts/gen-opencode-config.go
{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000
  },
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": false,
    "mcp_timeout": 30000,
    "openTelemetry": true,
    "primary_tools": [
      "read",
      "grep",
      "glob",
      "edit",
      "write",
      "bash"
    ]
  },
  "formatter": {
    "gofmt": {
      "command": [
        "gofmt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".go"
      ]
    },
    "oxfmt": {
      "command": [
        "oxfmt",
        "$FILE"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts",
        ".jsx",
        ".css",
        ".scss",
        ".less",
        ".html",
        ".vue",
        ".json",
        ".jsonc",
        ".json5",
        ".yaml",
        ".yml",
        ".md",
        ".mdx",
        ".graphql",
        ".gql"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "terraform": {
      "command": [
        "terraform",
        "fmt",
        "$FILE"
      ],
      "extensions": [
        ".tf",
        ".hcl",
        ".tfvars"
      ]
    }
  },
  "instructions": [
    "~/.config/opencode/rules/00-hard-autonomy-no-questions.md",
    "~/.config/opencode/rules/00-archon-workflow.md",
    "~/.config/opencode/rules/00-session-init.md",
    "~/.config/opencode/rules/00-requirements-verification.md",
    "~/.config/opencode/rules/00-monorepo-standards.md",
    "~/.config/opencode/rules/00-code-modularization.md"
  ],
  "logLevel": "INFO",
  "lsp": {
    "css": {
      "command": [
        "vscode-css-language-server",
        "--stdio"
      ],
      "extensions": [
        ".css",
        ".scss",
        ".less"
      ],
      "initialization": {
        "css": {
          "validate": true
        },
        "less": {
          "validate": true
        },
        "provideFormatter": false,
        "scss": {
          "validate": true
        }
      }
    },
    "dockerfile": {
      "command": [
        "docker-langserver",
        "--stdio"
      ],
      "extensions": [
        "Dockerfile"
      ],
      "initialization": {
        "docker": {
          "languageserver": {
            "diagnostics": {
              "deprecatedMaintainer": "warning",
              "directiveCasing": "warning",
              "instructionWorkdirRelative": "warning"
            }
          }
        }
      }
    },
    "eslint": {
      "command": [
        "vscode-eslint-language-server",
        "--stdio"
      ],
      "extensions": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts"
      ],
      "initialization": {
        "eslint": {
          "codeAction": {
            "disableRuleComment": {
              "enable": true
            },
            "showDocumentation": {
              "enable": true
            }
          },
          "format": {
            "enable": false
          },
          "quiet": false,
          "run": "onSave",
          "validate": "on"
        }
      }
    },
    "go": {
      "command": [
        "gopls"
      ],
      "env": {
        "GO111MODULE": "on"
      },
      "extensions": [
        ".go"
      ],
      "initialization": {
        "gopls": {
          "analyses": {
            "nilness": true,
            "shadow": true,
            "unusedparams": true,
            "unusedwrite": true,
            "useany": true
          },
          "completeUnimported": true,
          "directoryFilters": [
            "-node_modules",
            "-.git",
            "-.cache",
            "-tmp"
          ],
          "gofumpt": true,
          "staticcheck": true,
          "usePlaceholders": true
        }
      }
    },
    "html": {
      "command": [
        "vscode-html-language-server",
        "--stdio"
      ],
      "extensions": [
        ".html"
      ],
      "initialization": {
        "provideFormatter": false
      }
    },
    "json": {
      "command": [
        "vscode-json-language-server",
        "--stdio"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ],
      "initialization": {
        "json": {
          "schemas": [
            {
              "fileMatch": [
                "package.json"
              ],
              "url": "https://json.schemastore.org/package.json"
            },
            {
              "fileMatch": [
                "tsconfig*.json"
              ],
              "url": "https://json.schemastore.org/tsconfig.json"
            },
            {
              "fileMatch": [
                ".eslintrc",
                ".eslintrc.json"
              ],
              "url": "https://json.schemastore.org/eslintrc.json"
            }
          ],
          "validate": {
            "enable": true
          }
        },
        "provideFormatter": false
      }
    },
    "lua": {
      "command": [
        "lua-language-server"
      ],
      "extensions": [
        ".lua"
      ],
      "initialization": {
        "Lua": {
          "diagnostics": {
            "enable": true,
            "globals": [
              "vim"
            ],
            "workspaceDelay": 3000,
            "workspaceEvent": "OnSave",
            "workspaceRate": 100
          },
          "hint": {
            "enable": true,
            "paramName": "Disable",
            "semicolon": "Disable"
          },
          "runtime": {
            "path": [
              "lua/?.lua",
              "lua/?/init.lua"
            ],
            "pathStrict": false,
            "version": "LuaJIT"
          },
          "workspace": {
            "checkThirdParty": false,
            "library": [
              "${workspaceFolder}"
            ]
          }
        }
      }
    },
    "markdown": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".mdx"
      ]
    },
    "python": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ],
      "initialization": {
        "basedpyright": {
          "analysis": {
            "autoImportCompletions": true,
            "autoSearchPaths": true,
            "configFilePath": "${workspaceFolder}",
            "diagnosticMode": "openFilesOnly",
            "diagnosticSeverityOverrides": {
              "reportMissingTypeStubs": "none"
            },
            "inlayHints": {
              "callArgumentNames": true,
              "functionReturnTypes": true,
              "genericTypes": true,
              "variableTypes": true
            },
            "typeCheckingMode": "recommended",
            "useLibraryCodeForTypes": true
          }
        }
      }
    },
    "rust": {
      "command": [
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ],
      "initialization": {
        "cargo": {
          "allTargets": true,
          "buildScripts": {
            "enable": true
          },
          "features": "all"
        },
        "check": {
          "allTargets": true,
          "command": "clippy",
          "extraArgs": [
            "--",
            "-Dwarnings"
          ]
        },
        "checkOnSave": true,
        "files": {
          "exclude": [
            ".git",
            "target",
            "node_modules",
            "tmp",
            ".cache"
          ],
          "watcher": "client"
        },
        "inlayHints": {
          "chainingHints": {
            "enable": true
          },
          "parameterHints": {
            "enable": true
          },
          "typeHints": {
            "enable": true
          }
        },
        "procMacro": {
          "enable": true
        }
      }
    },
    "tailwindcss": {
      "command": [
        "tailwindcss-language-server",
        "--stdio"
      ],
      "extensions": [
        ".html",
        ".css",
        ".scss",
        ".jsx",
        ".tsx",
        ".vue",
        ".svelte"
      ],
      "initialization": {
        "tailwindCSS": {
          "codeActions": true,
          "hovers": true,
          "lint": {
            "cssConflict": "warning",
            "invalidApply": "error",
            "invalidConfigPath": "error",
            "invalidScreen": "error",
            "invalidTailwindDirective": "error",
            "invalidVariant": "error",
            "recommendedVariantOrder": "warning"
          },
          "suggestions": true,
          "validate": true
        }
      }
    },
    "terraform": {
      "command": [
        "terraform-ls",
        "serve"
      ],
      "extensions": [
        ".tf",
        ".hcl",
        ".tfvars"
      ],
      "initialization": {
        "experimentalFeatures": {
          "validateOnSave": true
        }
      }
    },
    "toml": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".mts",
        ".cjs",
        ".cts"
      ],
      "initialization": {
        "maxTsServerMemory": 6144,
        "preferences": {
          "importModuleSpecifierEnding": "minimal",
          "importModuleSpecifierPreference": "project-relative",
          "includeCompletionsForImportStatements": true,
          "includeCompletionsForModuleExports": true,
          "includeInlayEnumMemberValueHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": false,
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includePackageJsonAutoImports": "on",
          "interactiveInlayHints": true,
          "organizeImportsTypeOrder": "last"
        },
        "tsserver": {
          "trace": "off",
          "useSyntaxServer": "auto"
        }
      }
    },
    "yaml": {
      "command": [
        "yaml-language-server",
        "--stdio"
      ],
      "extensions": [
        ".yaml",
        ".yml"
      ],
      "initialization": {
        "yaml": {
          "completion": true,
          "format": {
            "enable": false
          },
          "hover": true,
          "schemas": {
            "https://json.schemastore.org/chart.json": "Chart.yaml",
            "https://json.schemastore.org/dependabot-2.0.json": ".github/dependabot.yml",
            "https://json.schemastore.org/docker-compose.json": "docker-compose*.yml",
            "https://json.schemastore.org/github-action.json": "action.yml",
            "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml",
            "https://json.schemastore.org/kustomization.json": "kustomization.yaml"
          },
          "validate": true
        }
      }
    }
  },
  "mcp": {
    "mcphub": {
      "enabled": true,
      "timeout": 30000,
      "type": "remote",
      "url": "http://192.168.50.112:3000/mcp"
    }
  },
  "model": "",
  "permission": {
    "*": "allow"
  },
  "plugin": [
    "opencode-claude-auth",
    "oh-my-openagent"
  ],
  "provider": {},
  "share": "manual",
  "small_model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
  "snapshot": true,
  "theme": "tron",
  "username": "jclee",
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/.next/**",
      "**/.venv/**",
      "**/coverage/**",
      "**/.terraform/**",
      "**/terraform.tfstate*",
      "**/.cache/**",
      "**/.sisyphus/**",
      "**/logs/**",
      "**/log/**",
      "**/data/**",
      "**/profiles/**",
      "**/tmp/**",
      "**/build/**",
      "**/__pycache__/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.pytest_cache/**",
      "**/.turbo/**",
      "**/.angular/**",
      "**/.svelte-kit/**",
      "**/.nuxt/**",
      "**/.output/**",
      "**/.parcel-cache/**",
      "**/.vercel/**",
      "**/target/**",
      "**/.cargo/**",
      "**/*.log",
      "**/*.pyc",
      "**/*.db",
      "**/*.pid",
      "**/*.tmp",
      "**/*.swp",
      "**/*~",
      "**/.DS_Store",
      "**/*.bak.*",
      "**/*.backup-*",
      "**/*.tsbuildinfo"
    ]
  }
}
