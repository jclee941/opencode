{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,

  // ============================================================
  // AGENTS — 15 agents with role-appropriate permissions
  // ============================================================
  "agents": {
    // --- Primary orchestrator (Claude-native, NO GPT prompt exists) ---
    "sisyphus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max"
    },

    // --- Deep autonomous worker (GPT-native, built for Codex) ---
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },

    // --- Planner / Strategist ---
    "prometheus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- Pre-planning consultant ---
    "metis": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- READ-ONLY high-IQ consultant ---
    "oracle": {
      "model": "openai/gpt-5.2",
      "variant": "high",
      "permission": { "edit": "deny", "bash": "deny", "webfetch": "deny" }
    },

    // --- Expert reviewer ---
    "momus": {
      "model": "openai/gpt-5.2",
      "variant": "medium",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- External reference search ---
    "librarian": {
      "model": "google/antigravity-claude-sonnet-4-6",
      "permission": { "edit": "deny" }
    },

    // --- Contextual grep ---
    // NOTE: grok-code-fast-1 (official 1st priority) returns 400 invalid_request_body
    // from api.githubcopilot.com — reverted to claude-haiku-4-5 (official 2nd fallback)
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "permission": { "edit": "deny" }
    },

    // --- Visual analysis ---
    "multimodal-looker": {
      "model": "google/antigravity-gemini-3-flash",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- Session/context manager ---
    "atlas": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },

    // --- Delegated sub-agent (default for task() calls) ---
    "sisyphus-junior": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },

    // --- Internal builders/planners ---
    "build": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },
    "plan": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "permission": { "edit": "deny", "bash": "deny" }
    },
    "OpenCode-Builder": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },

    // NOTE: unspecified-high / unspecified-low are CATEGORY names,
    // NOT agent names. Removed from agents; kept in categories below.
  },

  // ============================================================
  // CATEGORIES — with thinking/reasoning tuning
  // ============================================================
  "categories": {
    "visual-engineering": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "reasoningEffort": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "reasoningEffort": "high",
      "thinking": { "type": "enabled", "budgetTokens": 16384 }
    },
    "artistry": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "reasoningEffort": "high",
      "temperature": 0.8
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "reasoningEffort": "low"
    },
    "unspecified-low": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },
    "unspecified-high": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },
    "writing": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "medium",
      "textVerbosity": "high",
      "reasoningEffort": "medium"
    }
  },

  // ============================================================
  // SISYPHUS AGENT — planner & builder control
  // ============================================================
  "sisyphus_agent": {
    "planner_enabled": true,
    "default_builder_enabled": true
  },

  // ============================================================
  // BACKGROUND TASK — parallel agent concurrency
  // ============================================================
  "background_task": {
    "defaultConcurrency": 10,
    "providerConcurrency": {
      "openai": 100,
      "google": 100
    },
    // Issue #1925 workaround — xhigh/deep models need longer timeouts
    // Hephaestus (GPT-5.3-codex) thinks long without emitting tool calls,
    // triggering stale detection. Maintainer-recommended values:
    "staleTimeoutMs": 600000,            // 10 min (was 5 min, default 3 min)
    "messageStalenessTimeoutMs": 1800000 // 30 min (was default 10 min)
  },

  // ============================================================
  // EXPERIMENTAL — dynamic context pruning
  // ============================================================
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 3 },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 5 }
      }
    }
  },

  // ============================================================
  // RALPH LOOP — iteration cap for cost control
  // ============================================================
  "ralph_loop": {
    "default_max_iterations": 50
  },

  // ============================================================
  // GIT MASTER — commit metadata
  // ============================================================
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  }
}
