{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",

  // ============================================================
  // PROVIDER CONTEXT (for reference — defined in opencode.jsonc)
  // Available (google provider only):
  //   google/antigravity-claude-opus-4-6-thinking  (variants: low, max)
  //   google/antigravity-claude-sonnet-4-6
  //   google/antigravity-gemini-3-pro               (variants: low, high)
  //   google/antigravity-gemini-3-flash             (variants: minimal, low, medium, high)
  // NOT available: openai, github-copilot, kimi-for-coding, zai-coding-plan
  // ============================================================

  // ============================================================
  // AGENTS — lowercase keys only (source: src/shared/agent-display-names.ts)
  // Builtin agents: sisyphus, hephaestus, oracle, librarian, explore,
  //                 multimodal-looker, metis, momus, atlas
  // ============================================================
  "agents": {
    // --- Primary orchestrator ---
    // Canonical: anthropic/claude-opus-4-6 (max)
    // Best available: google/antigravity-claude-opus-4-6-thinking (max)
    "sisyphus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max"
    },

    // --- Deep autonomous worker (Hephaestus) ---
    // Canonical: openai/gpt-5.3-codex (medium) — NOT available on any provider
    // requiresProvider: openai/github-copilot/opencode — hephaestus won't activate without them.
    // Override with best available deep-coding model as safety net in case
    // requiresProvider gate is bypassed or opencode provider activates.
    "hephaestus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max"
    },

    // --- Strategic consultant (READ-ONLY) ---
    // Fallback chain: openai → google/gemini-3-pro → anthropic/claude-opus-4-6
    // Best available: google/antigravity-gemini-3-pro (high thinking)
    "oracle": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "permission": { "edit": "deny", "bash": "deny", "webfetch": "deny" }
    },

    // --- Documentation/reference researcher (UTILITY — speed > intelligence) ---
    // Guide: "Doc retrieval doesn't need deep reasoning"
    // Default chain: MiniMax Free → Gemini Flash → Big Pickle
    // Best available: google/antigravity-gemini-3-flash (low thinking)
    "librarian": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "low",
      "permission": { "edit": "deny" }
    },

    // --- Fast codebase grep / exploration ---
    // Canonical: github-copilot/grok-code-fast-1 → anthropic/claude-haiku-4-5
    // Best available: google/antigravity-gemini-3-flash (minimal thinking = fast)
    "explore": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "minimal",
      "permission": { "edit": "deny" }
    },

    // --- Visual / multimodal analysis ---
    // Fallback chain: google/gemini-3-flash → openai → zai → kimi → anthropic
    // Best available: google/antigravity-gemini-3-flash (medium thinking)
    "multimodal-looker": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "medium",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- Pre-planning consultant (READ-ONLY) ---
    // Fallback chain: anthropic/claude-opus-4-6 (max) → kimi → openai → google
    // Best available: google/antigravity-claude-opus-4-6-thinking (max)
    "metis": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- Plan critic / reviewer (READ-ONLY) ---
    // Fallback chain: openai/gpt-5.2 (medium) → anthropic/claude-opus-4-6 → google/gemini-3-pro
    // Best available: google/antigravity-claude-opus-4-6-thinking (low thinking budget)
    "momus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "low",
      "permission": { "edit": "deny", "bash": "deny" }
    },

    // --- Session/context manager & task executor ---
    // Fallback chain: kimi/k2p5 → opencode → anthropic/claude-sonnet-4-6 → openai → google
    // Best available: google/antigravity-claude-sonnet-4-6
    "atlas": {
      "model": "google/antigravity-claude-sonnet-4-6"
    }
  },

  // ============================================================
  // CATEGORIES — ALL 8 must be explicit (⚠️ NO auto-defaults)
  // Source: src/shared/model-requirements.ts CATEGORY_MODEL_REQUIREMENTS
  // ============================================================
  "categories": {
    // Frontend / UI / design — primary: google/gemini-3-pro (high)
    // Best available: google/antigravity-gemini-3-pro (high)
    "visual-engineering": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "reasoningEffort": "high"
    },

    // Deep logical reasoning — primary: openai/gpt-5.3-codex (xhigh)
    // Guide chain: GPT-5.3-codex → Gemini 3 Pro → Opus (Gemini Pro is 2nd choice)
    // GPT unavailable → use Gemini Pro (high thinking)
    "ultrabrain": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },

    // Goal-oriented autonomous solving — primary: openai/gpt-5.3-codex (medium)
    // requiresModel: gpt-5.3-codex → NOT available, category won't auto-activate
    // Override with best available reasoning model
    "deep": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "thinking": { "type": "enabled", "budgetTokens": 16384 }
    },

    // Creative / artistic — primary: google/gemini-3-pro (high)
    // requiresModel: gemini-3-pro — "antigravity-gemini-3-pro" may or may not match
    // Override explicitly to ensure it resolves
    "artistry": {
      "model": "google/antigravity-gemini-3-pro",
      "variant": "high",
      "temperature": 0.8,
      "reasoningEffort": "high"
    },

    // Trivial/fast tasks — primary: anthropic/claude-haiku-4-5
    // Best available: google/antigravity-gemini-3-flash (minimal thinking)
    "quick": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "minimal"
    },

    // General low-effort tasks — primary: anthropic/claude-sonnet-4-6
    // Best available: google/antigravity-claude-sonnet-4-6
    "unspecified-low": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },

    // General high-effort tasks — primary: anthropic/claude-opus-4-6 (max)
    // Best available: google/antigravity-claude-opus-4-6-thinking (max)
    "unspecified-high": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },

    // Documentation / prose / technical writing — primary: kimi/k2p5
    // kimi not available → fallback: google/gemini-3-flash (good for writing)
    "writing": {
      "model": "google/antigravity-gemini-3-flash",
      "variant": "medium",
      "textVerbosity": "high",
      "reasoningEffort": "medium"
    }
  },

  // ============================================================
  // SISYPHUS AGENT — orchestrator control
  // Source: docs/configurations.md#sisyphus-agent
  // ============================================================
  "sisyphus_agent": {
    "planner_enabled": true,       // Enable Prometheus (Planner) agent
    "default_builder_enabled": false // OpenCode-Builder disabled (Sisyphus handles it)
  },

  // ============================================================
  // BACKGROUND TASK — parallel agent concurrency
  // Source: src/config/schema/background-task.ts
  // ============================================================
  "background_task": {
    "defaultConcurrency": 5,
    // Official defaults restored (v3.7.4: src/config/schema/background-task.ts)
    "staleTimeoutMs": 180000,             // 3 min (official default)
    "messageStalenessTimeoutMs": 600000,  // 10 min (official default)
    // Per-provider concurrency (google = antigravity quota, generous)
    "providerConcurrency": {
      "google": 10
    },
    // Per-model: cap expensive thinking models to control cost
    "modelConcurrency": {
      "google/antigravity-claude-opus-4-6-thinking": 2
    }
  },

  // ============================================================
  // EXPERIMENTAL — dynamic context pruning
  // Source: docs/configurations.md#experimental
  // ============================================================
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": { "enabled": true, "turns": 3 },
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": { "enabled": true, "aggressive": false },
        "purge_errors": { "enabled": true, "turns": 5 }
      }
    }
  },

  // ============================================================
  // RALPH LOOP — iteration cap for cost control
  // ============================================================
  "ralph_loop": {
    "default_max_iterations": 50
  },

  // ============================================================
  // GIT MASTER — commit metadata
  // Source: docs/configurations.md#git-master
  // ============================================================
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  }
}
