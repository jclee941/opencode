{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },
    "explore": {
      "model": "minimax-coding-plan/MiniMax-M2.5-highspeed"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex"
    },
    "librarian": {
      "model": "openai/gpt-5.2"
    },
    "metis": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.2"
    },
    "multimodal-looker": {
      "model": "google/antigravity-gemini-3-flash"
    },
    "oracle": {
      "model": "openai/gpt-5.2"
    },
    "sisyphus": {
      "model": "google/antigravity-claude-opus-4-6-thinking"
    }
  },
  "background_task": {
    "defaultConcurrency": 3,
    "messageStalenessTimeoutMs": 900000,
    "modelConcurrency": {
      "google/antigravity-claude-opus-4-6-thinking": 1
    },
    "staleTimeoutMs": 300000
  },
  "categories": {
    "artistry": {
      "model": "google/antigravity-gemini-3.1-pro"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex"
    },
    "quick": {
      "model": "google/antigravity-gemini-3-flash"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max"
    },
    "unspecified-low": {
      "model": "google/antigravity-claude-sonnet-4-6"
    },
    "visual-engineering": {
      "model": "google/antigravity-gemini-3.1-pro",
      "reasoningEffort": "high",
      "variant": "high"
    },
    "writing": {
      "model": "google/antigravity-gemini-3-flash"
    }
  },
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": false,
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        },
        "supersede_writes": {
          "aggressive": false,
          "enabled": true
        }
      }
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  },
  "google_auth": false,
  "ralph_loop": {
    "default_max_iterations": 50
  },
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "planner_enabled": true
  },
  "_migrations": [
    "model-version:openai/gpt-5.2-codex->openai/gpt-5.3-codex"
  ]
}
