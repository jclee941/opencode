{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "textVerbosity": "medium",
      "fallback_models": [
        "google/antigravity-claude-sonnet-4-6",
        "openai/gpt-5.4",
        "opencode-go/glm-5"
      ],
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },
    "metis": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "textVerbosity": "high",
      "fallback_models": ["openai/gpt-5.4", "opencode-go/glm-5"],
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },
    "prometheus": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "textVerbosity": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "opencode-go/glm-5",
        "google/gemini-3.1-pro-preview"
      ],
      "thinking": { "type": "enabled", "budgetTokens": 32768 }
    },
    "atlas": {
      "model": "google/antigravity-claude-sonnet-4-6",
      "textVerbosity": "medium",
      "fallback_models": ["openai/gpt-5.4"]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "high",
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "google/antigravity-claude-opus-4-6-thinking",
        "opencode-go/glm-5"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "google/antigravity-claude-opus-4-6-thinking",
        "google/gemini-3.1-pro-preview",
        "opencode-go/glm-5"
      ]
    },
    "librarian": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "textVerbosity": "low",
      "fallback_models": [
        "minimax-coding-plan/MiniMax-M2.7-highspeed",
        "anthropic/claude-haiku-4-5"
      ]
    },
    "explore": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "textVerbosity": "low",
      "fallback_models": [
        "minimax-coding-plan/MiniMax-M2.7",
        "anthropic/claude-haiku-4-5"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "textVerbosity": "low",
      "fallback_models": [
        "google/antigravity-claude-sonnet-4-6",
        "google/gemini-3-flash-preview"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "textVerbosity": "low",
      "fallback_models": [
        "openai/gpt-5.4",
        "google/antigravity-claude-opus-4-6-thinking"
      ]
    },
    "ralph": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "allow_non_gpt_model": true,
      "fallback_models": [
        "openai/gpt-5.4",
        "google/antigravity-claude-opus-4-6-thinking"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "reasoningEffort": "high",
      "fallback_models": [
        "opencode-go/glm-5",
        "google/antigravity-claude-opus-4-6-thinking",
        "google/antigravity-claude-sonnet-4-6"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "google/antigravity-claude-opus-4-6-thinking",
        "opencode-go/glm-5"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "google/antigravity-claude-opus-4-6-thinking",
        "google/gemini-3.1-pro-preview"
      ]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "google/antigravity-claude-opus-4-6-thinking",
        "openai/gpt-5.4"
      ]
    },
    "quick": {
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": [
        "anthropic/claude-haiku-4-5",
        "google/gemini-3-flash-preview"
      ]
    },
    "unspecified-high": {
      "model": "google/antigravity-claude-opus-4-6-thinking",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.4", "opencode-go/glm-5"]
    },
    "unspecified-low": {
      "model": "google/antigravity-claude-sonnet-4-6",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "google/gemini-3-flash-preview"
      ]
    },
    "writing": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": [
        "google/antigravity-claude-sonnet-4-6",
        "anthropic/claude-haiku-4-5"
      ]
    }
  }
}
