{
  "scripts": {
    "test": "vitest run",
    "test:elk": "vitest run tests/elk",
    "test:watch": "vitest",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/commit-msg .githooks/pre-push",
    "commitlint": "commitlint --edit",
    "prepush:check": "npm run gen:config:check && npm run lint:naming && npm run lint:config-refs",
    "gen:config": "go run scripts/gen-opencode-config.go",
    "gen:config:check": "go run scripts/gen-opencode-config.go --check",
    "lint:naming": "node scripts/validate-monorepo-naming.mjs",
    "lint:config-refs": "go run scripts/validate-config-refs.go",
    "lint:assistant-phrasing": "node scripts/lint-assistant-phrasing.mjs",
    "kratos:sync": "go run scripts/kratos-project-sync.go sync",
    "kratos:install": "go run scripts/kratos-project-sync.go install",
    "kratos:uninstall": "go run scripts/kratos-project-sync.go uninstall",
    "telegram:bot": "go run scripts/antigravity-telegram-bot.go"
  },
  "dependencies": {
    "@nick-vi/opencode-type-inject": "^1.5.1",
    "@opencode-ai/plugin": "1.2.20",
    "@openspoon/subtask2": "^0.3.9",
    "@tarquinen/opencode-dcp": "^2.1.8",
    "opencode-antigravity-auth": "^1.6.0",
    "opencode-image-compress": "^0.3.2",
    "opencode-lazy-loader": "^1.0.3",
    "opencode-mem": "^2.11.6",
    "opencode-pilot": "^0.27.0",
    "opencode-pty": "^0.2.3",
    "opencode-shell-non-interactive-strategy": "github:JRedeker/opencode-shell-strategy",
    "opencode-tps-meter": "^0.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "vitest": "^4.0.18"
  }
}