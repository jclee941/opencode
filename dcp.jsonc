{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "protectedFilePatterns": [
    "config/*.jsonc",
    "oh-my-opencode.jsonc",
    "opencode.jsonc",
    "rules/*.md",
    "AGENTS.md",
  ],
  "commands": {
    "enabled": true,
    "protectedTools": [
      "task",
      "todowrite",
      "todoread",
      "distill",
      "compress",
      "prune",
      "batch",
      "plan_enter",
      "plan_exit",
      "write",
      "edit",
    ],
  },
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true,
  },
  "turnProtection": {
    "enabled": true,
    "turns": 2,
  },
  "tools": {
    "settings": {
      "nudgeEnabled": true,
      "nudgeFrequency": 5,
      "contextLimit": 150000,
      "protectedTools": ["task", "todowrite", "write", "edit"],
      "modelLimits": {
        "google/antigravity-claude-opus-4-6-thinking": 180000,
        "google/antigravity-claude-sonnet-4-6": 180000,
        "google/antigravity-gemini-3.1-pro": "95%",
        "google/antigravity-gemini-3.1-flash": "95%",
        "minimax-coding-plan/MiniMax-M2.5": "90%",
        "minimax-coding-plan/MiniMax-M2.5-highspeed": "90%",
      },
    },
    "distill": {
      "permission": "allow",
      "showDistillation": true,
    },
    "compress": {
      "permission": "allow",
      "showCompression": true,
    },
    "prune": {
      "permission": "allow",
    },
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      "protectedTools": ["task", "write", "edit"],
    },
    "supersedeWrites": {
      "enabled": true,
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 5,
      "protectedTools": ["task", "edit"],
    },
  },
}
