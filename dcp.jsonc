{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": true,
  "debug": false,
  "pruneNotification": "minimal",
  "pruneNotificationType": "chat",
  "protectedFilePatterns": [
    "config/*.jsonc",
    "oh-my-opencode.jsonc",
    "opencode.jsonc",
    "rules/*.md",
    "AGENTS.md",
  ],
  "commands": {
    "enabled": true,
    // Broadest scope: tools exempt from ALL DCP command-driven pruning.
    // Superset of strategy-level protectedTools below.
    "protectedTools": [
      "task",
      "todowrite",
      "todoread",
      "distill",
      "compress",
      "prune",
      "batch",
      "plan_enter",
      "plan_exit",
      "write",
      "edit",
    ],
  },
  "manualMode": {
    "enabled": false,
    "automaticStrategies": true,
  },
  "turnProtection": {
    "enabled": true,
    "turns": 2,
  },
  "tools": {
    "settings": {
      "nudgeEnabled": true,
      "nudgeFrequency": 4,
      // Soft token budget for nudge triggers. Not a hard cap.
      // Relationship: contextLimit < modelLimits < provider context.
      "contextLimit": 140000,
      // Tools exempt from automatic context-management nudges.
      "protectedTools": ["task", "todowrite", "write", "edit"],
      // Per-model hard limits. Values: absolute tokens or "%" of provider context.
      // Provider context (providers.jsonc): claude=200000, gemini=1048576.
      "modelLimits": {
        "google/antigravity-claude-opus-4-6-thinking": "80%",
        "google/antigravity-claude-sonnet-4-6": "80%",
        "google/antigravity-gemini-3.1-pro": "80%",
        "google/antigravity-gemini-3.1-flash": "80%",
        "minimax-coding-plan/MiniMax-M2.5": "80%",
        "minimax-coding-plan/MiniMax-M2.5-highspeed": "80%",
        "openai/gpt-5.3-codex": "80%",
        "openai/gpt-5.4-pro": "80%",
        "google/antigravity-gemini-3.1-pro-preview": "80%",
        "opencode-go/kimi-k2.5": "80%",
        "opencode-go/glm-5": "80%",
        "opencode-go/minimax-m2.5": "80%",
      },
    },
    "distill": {
      "permission": "allow",
      "showDistillation": true,
    },
    "compress": {
      "permission": "allow",
      "showCompression": true,
    },
    "prune": {
      "permission": "allow",
    },
  },
  "strategies": {
    "deduplication": {
      "enabled": true,
      // Strategy-level: tools whose outputs must never be deduplicated.
      "protectedTools": ["task", "write", "edit"],
    },
    "supersedeWrites": {
      "enabled": true,
    },
    "purgeErrors": {
      "enabled": true,
      "turns": 5,
      // Strategy-level: tools whose errors must not be purged.
      "protectedTools": ["task", "edit"],
    },
  },
}
