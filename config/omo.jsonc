{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "auto_update": true,
  "new_task_system_enabled": true,

  // Model variables — change a model string in one place, all references update.
  // Resolved by: go run scripts/gen-omo-config.go → oh-my-opencode.jsonc
  "$models": {
    "$CLAUDE_OPUS": "kimi-for-coding/k2p5",
    "$CLAUDE_SONNET": "kimi-for-coding/k2p5",
    "$CLAUDE_HAIKU": "anthropic/claude-haiku-4-5",
    "$GEMINI_PRO": "minimax-coding-plan/MiniMax-M2.7",
    "$GEMINI_FLASH": "minimax-coding-plan/MiniMax-M2.7-highspeed"
  },

  "background_task": {
    "defaultConcurrency": 99,
    "messageStalenessTimeoutMs": 900000,
    "modelConcurrency": {
      "$CLAUDE_OPUS": 5,
      "$CLAUDE_SONNET": 10,
      "$CLAUDE_HAIKU": 20,
      "openai/gpt-5.4": 99,
      "openai/gpt-5.3-codex": 99,
      "$GEMINI_PRO": 10,
      "$GEMINI_FLASH": 20,
      "opencode-go/glm-5": 99,
      "minimax-coding-plan/MiniMax-M2.7-highspeed": 99
    },
    "staleTimeoutMs": 300000
  },
  "runtime_fallback": {
    "enabled": true,
    "max_fallback_attempts": 3,
    "cooldown_seconds": 8,
    "timeout_seconds": 25,
    "retry_on_errors": [429, 503, 408, 502, 500, 529, 504, 522, 524],
    "notify_on_fallback": true
  },
  "model_fallback": true,
  "hashline_edit": true,
  "notification": {
    "force_enable": true
  },
  "websearch": {
    "provider": "exa"
  },
  "browser_automation_engine": {
    "provider": "playwright"
  },
  "babysitting": {
    "timeout_ms": 180000
  },
  "disabled_hooks": ["startup-toast", "tips_toggle"],
  "categories": {
    "visual-engineering": {
      "description": "Frontend and UI — Gemini Pro primary",
      "model": "$GEMINI_PRO",
      "reasoningEffort": "high",
      "variant": "high",
      "fallback_models": [
        "opencode-go/glm-5",
        "$CLAUDE_OPUS",
        "$CLAUDE_SONNET"
      ]
    },
    "ultrabrain": {
      "description": "Maximum reasoning — GPT-5.4 primary",
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        "$GEMINI_PRO",
        "$CLAUDE_OPUS",
        "opencode-go/glm-5"
      ]
    },
    "deep": {
      "description": "Deep coding — GPT Codex primary",
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "$CLAUDE_OPUS",
        "$GEMINI_PRO"
      ]
    },
    "artistry": {
      "description": "Creative approaches — Gemini Pro primary",
      "model": "$GEMINI_PRO",
      "variant": "high",
      "fallback_models": [
        "$CLAUDE_OPUS",
        "openai/gpt-5.4"
      ]
    },
    "quick": {
      "description": "Simple fast tasks — MiniMax highspeed",
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "fallback_models": [
        "$CLAUDE_HAIKU",
        "$GEMINI_FLASH"
      ]
    },
    "unspecified-high": {
      "description": "General complex — Opus tier",
      "model": "$CLAUDE_OPUS",
      "variant": "max",
      "fallback_models": [
        "openai/gpt-5.4",
        "opencode-go/glm-5"
      ]
    },
    "unspecified-low": {
      "description": "General standard — Sonnet tier",
      "model": "$CLAUDE_SONNET",
      "fallback_models": [
        "openai/gpt-5.3-codex",
        "$GEMINI_FLASH"
      ]
    },
    "writing": {
      "description": "Documentation — Gemini Flash primary",
      "model": "$GEMINI_FLASH",
      "fallback_models": [
        "$CLAUDE_SONNET",
        "$CLAUDE_HAIKU"
      ]
    }
  },
  "experimental": {
    "safe_hook_creation": true,
    "model_fallback_title": true,
    "plugin_load_timeout_ms": 15000
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 50,
    "default_strategy": "continue"
  },
  "agents": {
    "sisyphus": {
      "description": "Kimi K2.5 (rate limit bypass)",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "textVerbosity": "medium",
      "fallback_models": [
        "$CLAUDE_SONNET",
        "openai/gpt-5.4",
        "opencode-go/glm-5"
      ]
    },
    "junior": {
      "description": "Sisyphus-Junior — Claude Sonnet tier",
      "model": "$CLAUDE_SONNET",
      "textVerbosity": "low",
      "fallback_models": [
        "$CLAUDE_OPUS",
        "openai/gpt-5.4"
      ]
    },
    "hephaestus": {
      "description": "Autonomous code builder — GPT Codex (deep specialist)",
      "model": "openai/gpt-5.3-codex",
      "textVerbosity": "low",
      "fallback_models": [
        "openai/gpt-5.4",
        "$CLAUDE_OPUS"
      ],
      "prompt_append": "Follow existing codebase patterns. Run lsp_diagnostics."
    },
    "prometheus": {
      "description": "Kimi K2.5 (rate limit bypass)",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "textVerbosity": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "opencode-go/glm-5",
        "$GEMINI_PRO"
      ],
      "prompt_append": "Output structured implementation plan."
    },
    "metis": {
      "description": "Kimi K2.5 (rate limit bypass)",
      "model": "kimi-for-coding/k2p5",
      "variant": "max",
      "textVerbosity": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "opencode-go/glm-5"
      ],
      "prompt_append": "Analyze hidden intentions and ambiguities."
    },
    "explore": {
      "description": "Fast codebase search — speed over intelligence",
      "model": "minimax-coding-plan/MiniMax-M2.7-highspeed",
      "textVerbosity": "low",
      "fallback_models": [
        "minimax-coding-plan/MiniMax-M2.7",
        "$CLAUDE_HAIKU"
      ],
      "permission": {
        "*": "allow"
      },
      "prompt_append": "Focus on file paths and patterns."
    },
    "librarian": {
      "description": "Reference grep — fast utility model",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "textVerbosity": "low",
      "fallback_models": [
        "minimax-coding-plan/MiniMax-M2.7-highspeed",
        "$CLAUDE_HAIKU"
      ],
      "permission": {
        "*": "allow"
      },
      "prompt_append": "Search docs and references."
    },
    "oracle": {
      "description": "Architecture consultant — GPT-5.4 (deep specialist)",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "high",
      "fallback_models": [
        "$GEMINI_PRO",
        "$CLAUDE_OPUS",
        "opencode-go/glm-5"
      ],
      "permission": {
        "*": "allow"
      },
      "prompt_append": "Provide structured advisory output."
    },
    "momus": {
      "description": "Expert reviewer — GPT-5.4 xhigh (deep specialist)",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "xhigh",
      "fallback_models": [
        "$CLAUDE_OPUS",
        "$GEMINI_PRO",
        "opencode-go/glm-5"
      ],
      "permission": {
        "*": "allow"
      },
      "prompt_append": "Review for completeness and correctness."
    },
    "vision": {
      "description": "Vision specialist — GPT-5.4 multimodal",
      "model": "openai/gpt-5.4",
      "textVerbosity": "low",
      "fallback_models": [
        "$CLAUDE_SONNET",
        "$GEMINI_FLASH"
      ],
      "permission": {
        "*": "allow"
      }
    },
    "ralph": {
      "description": "Deep autonomous worker — GPT Codex tier",
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "allow_non_gpt_model": true,
      "fallback_models": [
        "openai/gpt-5.4",
        "$CLAUDE_OPUS"
      ],
      "prompt_append": "Follow patterns. Run diagnostics."
    },
    "atlas": {
      "description": "Kimi K2.5 (rate limit bypass)",
      "model": "kimi-for-coding/k2p5",
      "textVerbosity": "medium",
      "fallback_models": [
        "openai/gpt-5.4"
      ],
      "permission": {
        "*": "allow"
      },
      "prompt_append": "Map context comprehensively."
    }
  },
  "sisyphus_agent": {
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": true
  }
}
