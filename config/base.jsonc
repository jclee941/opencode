// Base configuration for OpenCode.
// Merged with config/providers.jsonc and config/lsp.jsonc by:
//   go run scripts/gen-opencode-config.go
{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tron",
  "username": "jclee",
  "logLevel": "INFO",

  "model": "",

  "instructions": [
    // Tier 0 — Always-loaded baseline rules (explicit listing).
    "~/.config/opencode/rules/00-hard-autonomy-no-questions.md",
    "~/.config/opencode/rules/00-archon-workflow.md",
    "~/.config/opencode/rules/00-session-init.md",
    "~/.config/opencode/rules/00-requirements-verification.md",
    "~/.config/opencode/rules/00-monorepo-standards.md",
    "~/.config/opencode/rules/00-code-modularization.md",
  ],

  "plugin": [
    "opencode-claude-auth",
    "oh-my-openagent"
  ],
  "mcp": {
    "mcphub": {
      "type": "remote",
      "url": "http://192.168.50.112:3000/mcp",
      "timeout": 30000,
      "enabled": true,
    },
  },

  "permission": {
    "*": "allow",
  },

  "experimental": {
    "continue_loop_on_deny": false,
    "batch_tool": true,
    "openTelemetry": true,
    "mcp_timeout": 30000,
    "primary_tools": ["read", "grep", "glob", "edit", "write", "bash"],
  },

  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 32000,
  },

  "small_model": "minimax-coding-plan/MiniMax-M2.7-highspeed",

  "formatter": {
    "oxfmt": {
      "command": ["oxfmt", "$FILE"],
      "extensions": [
        ".ts", ".tsx", ".js", ".mjs", ".mts", ".cjs", ".cts", ".jsx",
        ".css", ".scss", ".less", ".html", ".vue",
        ".json", ".jsonc", ".json5", ".yaml", ".yml",
        ".md", ".mdx", ".graphql", ".gql",
      ],
    },
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py"],
    },
    "gofmt": {
      "command": ["gofmt", "-w", "$FILE"],
      "extensions": [".go"],
    },
    "terraform": {
      "command": ["terraform", "fmt", "$FILE"],
      "extensions": [".tf", ".hcl", ".tfvars"],
    },
    "taplo": {
      "command": ["taplo", "fmt", "$FILE"],
      "extensions": [".toml"],
    },
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**", "**/.git/**", "**/dist/**", "**/.next/**",
      "**/.venv/**", "**/coverage/**", "**/.terraform/**", "**/terraform.tfstate*",
      "**/.cache/**", "**/.sisyphus/**", "**/logs/**", "**/log/**",
      "**/data/**", "**/profiles/**", "**/tmp/**", "**/build/**",
      "**/__pycache__/**", "**/.mypy_cache/**", "**/.ruff_cache/**",
      "**/.pytest_cache/**", "**/.turbo/**",
      "**/.angular/**", "**/.svelte-kit/**", "**/.nuxt/**", "**/.output/**",
      "**/.parcel-cache/**", "**/.vercel/**", "**/target/**", "**/.cargo/**",
      "**/*.log", "**/*.pyc", "**/*.db", "**/*.pid",
      "**/*.tmp", "**/*.swp", "**/*~", "**/.DS_Store",
      "**/*.bak.*", "**/*.backup-*",
      "**/*.tsbuildinfo",
    ],
  },

  "snapshot": true,
  "share": "manual",
}
